# Baza danych
# Lokalnie (SQLite): plik w folderze prisma
DATABASE_URL="file:./dev.db"
# Produkcja (Postgres / Neon) — zmień też provider w prisma/schema.prisma na "postgresql":
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Sekret do podpisywania sesji panelu admina (wygeneruj losowy długi ciąg)
AUTH_SECRET="zmien-mnie-na-dlugi-losowy-ciag-znakow"

# Dane pierwszego administratora (używane przez seed do utworzenia konta)
ADMIN_EMAIL="admin@mysterium.pl"
ADMIN_PASSWORD="zmien-to-haslo"
