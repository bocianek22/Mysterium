# Baza danych — projekt skonfigurowany pod Postgres (provider = "postgresql")
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Szybki start lokalny bez Postgresa: zmień provider w prisma/schema.prisma na
# "sqlite" i użyj:
# DATABASE_URL="file:./dev.db"

# Sekret do podpisywania sesji panelu admina (wygeneruj losowy długi ciąg)
AUTH_SECRET="zmien-mnie-na-dlugi-losowy-ciag-znakow"

# Dane pierwszego administratora (używane przez seed do utworzenia konta)
ADMIN_EMAIL="admin@mysterium.pl"
ADMIN_PASSWORD="zmien-to-haslo"

# (Opcjonalnie) Pełny adres strony — używany w metadanych SEO, OG i sitemapie.
# Jeśli pominiesz, na Vercel użyty zostanie automatyczny adres *.vercel.app.
# NEXT_PUBLIC_SITE_URL="https://mysterium.pl"

# (Opcjonalnie) E-mail transakcyjny — kampanie, podziękowania, kody bonów (Resend)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Mysterium <kontakt@twojadomena.pl>"   # wymaga zweryfikowanej domeny w Resend

# (Opcjonalnie) Cron — sekret do ręcznego wywołania zadań (auto-podziękowania)
# CRON_SECRET="dlugi-losowy-ciag"

# (Opcjonalnie) Płatności online — Stripe
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."   # webhook: checkout.session.completed → /api/pay/webhook/stripe

# (Opcjonalnie) Płatności online — Przelewy24
# P24_MERCHANT_ID="123456"
# P24_POS_ID="123456"
# P24_CRC="..."
# P24_API_KEY="..."
# P24_SANDBOX="true"   # false na produkcji; urlStatus → /api/pay/webhook/p24
