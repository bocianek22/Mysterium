// Mysterium Escape Room — schemat bazy danych
// Domyślnie SQLite (łatwy start lokalnie). Na produkcji (Vercel) zmień
// provider na "postgresql" i ustaw DATABASE_URL na bazę Postgres (np. Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Konto administratora (logowanie do panelu /admin)
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

// Pokoje zagadek (stacjonarne + mobilne)
model Room {
  id            String   @id @default(cuid())
  slug          String   @unique
  namePl        String
  nameEn        String
  taglinePl     String?
  taglineEn     String?
  descriptionPl String?  // pełny opis (strona pokoju)
  descriptionEn String?
  image         String?  // ścieżka do zdjęcia głównego
  durationMin   Int      @default(60)
  minPlayers    Int      @default(2)
  maxPlayers    Int      @default(8)
  difficultyPl  String   @default("Średni")
  difficultyEn  String   @default("Medium")
  badgePl       String   @default("Stacjonarny")
  badgeEn       String   @default("On-site")
  status        String   @default("ACTIVE") // ACTIVE | SOON
  bookingUrl    String?
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Galeria zdjęć
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  captionPl String?
  captionEn String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Galeria filmów (YouTube lub plik mp4)
model Video {
  id        String   @id @default(cuid())
  titlePl   String
  titleEn   String
  type      String   @default("YOUTUBE") // YOUTUBE | FILE
  youtubeId String?
  fileUrl   String?
  thumbnail String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Opinie graczy
model Review {
  id         String   @id @default(cuid())
  authorName String
  eventPl    String?
  eventEn    String?
  textPl     String
  textEn     String
  rating     Int      @default(5)
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// Pakiety cenowe
model PricingPlan {
  id        String   @id @default(cuid())
  namePl    String
  nameEn    String
  price     String   // tekst, np. "199 zł" albo "Wycena"
  descPl    String?
  descEn    String?
  featured  Boolean  @default(false)
  ctaUrl    String?
  order     Int      @default(0)
  published Boolean  @default(true)
}

// Pytania FAQ
model FaqItem {
  id         String   @id @default(cuid())
  questionPl String
  questionEn String
  answerPl   String
  answerEn   String
  order      Int      @default(0)
  published  Boolean  @default(true)
}

// Wiadomości z formularza kontaktowego
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  coupon    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Ustawienia strony (pojedynczy wiersz, id = "main")
model SiteSettings {
  id            String  @id @default("main")
  addressPl     String  @default("ul. Ogrodowa, Warszawa")
  addressEn     String  @default("Ogrodowa St., Warsaw")
  phone         String  @default("+48 571 080 192")
  email         String  @default("artsmysterium@gmail.com")
  whatsapp      String  @default("48571080192")
  lockmeUrl     String  @default("https://lock.me")
  instagram     String?
  facebook      String?
  hoursPl       String  @default("Pon–Nd: 9:00–22:00")
  hoursEn       String  @default("Mon–Sun: 9:00–22:00")
  heroDescPl    String  @default("Przenieś się do świata, gdzie każda sekunda ma znaczenie.")
  heroDescEn    String  @default("Step into a world where every second counts.")
  promoVideoPl  String? // YouTube ID lub URL pliku dla sekcji intro
  updatedAt     DateTime @updatedAt
}
