// Mysterium Escape Room — schemat bazy danych
// Domyślnie SQLite (łatwy start lokalnie). Na produkcji (Vercel) zmień
// provider na "postgresql" i ustaw DATABASE_URL na bazę Postgres (np. Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Konto użytkownika panelu — właściciel/admin lub pracownik
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  phone         String?
  role          String         @default("EMPLOYEE") // OWNER | ADMIN | EMPLOYEE
  active        Boolean        @default(true)
  // Stawki godzinowe (zł/h)
  rateDay       Float          @default(0)
  rateNight     Float          @default(0)
  rateWeekend   Float          @default(0)
  // Auto-grafik: umiejętności i cel godzinowy
  canStationary Boolean        @default(true)  // może obsługiwać stacjonarne
  canMobile     Boolean        @default(true)  // może jeździć na wyjazdy
  targetHours   Float          @default(0)      // cel godzin / miesiąc
  leaveAllowance Int           @default(26)     // roczny limit dni urlopu
  // Wynagrodzenie: stawki netto/brutto per kategoria (JSON) + typ umowy
  ratesJson     String?        @default("{}")   // {stationary:{net,brutto},mobile:{...},travel:{...},cleaning:{...}}
  contractType  String?        // UoP | Zlecenie | UoD | B2B (informacyjnie)
  telegramHandle String?       // @nick na Telegramie (referencyjnie)
  // Kalendarz
  calendarToken String         @unique @default(cuid()) // token subskrypcji iCal
  calendarEmbed String?        // URL osadzonego kalendarza Google w panelu
  telegramChatId String?       // opcjonalne powiadomienia 1:1
  createdAt     DateTime       @default(now())
  shifts        Shift[]
  availability  Availability[]
  timesheets    DailyTimesheet[] @relation("Timesheets")
  clockEntries  ClockEntry[]     @relation("ClockEntries")
  leaveRequests LeaveRequest[]   @relation("LeaveRequests")
  assignedReservations Reservation[] @relation("AssignedReservations")
}

// Wnioski urlopowe / niedostępność (z saldem dni wolnych)
model LeaveRequest {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("LeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime  // pierwszy dzień (00:00)
  endDate   DateTime  // ostatni dzień (włącznie)
  days      Float     @default(0) // dni robocze wniosku (liczone przy zapisie)
  type      String    @default("URLOP") // URLOP | NA_ZADANIE | BEZPLATNY | CHOROBA | INNE
  reason    String?
  status    String    @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedBy String?   // imię/e-mail osoby rozpatrującej
  decidedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([startDate])
}

// Rejestracja czasu pracy (RCP) — wejście/wyjście przez kod QR
model ClockEntry {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("ClockEntries", fields: [userId], references: [id], onDelete: Cascade)
  clockIn   DateTime  @default(now())
  clockOut  DateTime? // null = pracownik wciąż w pracy
  source    String    @default("QR") // QR | MANUAL
  note      String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([clockIn])
}

// Dzienna tabelka godzin wg kategorii (wypełnia pracownik) — podstawa wypłat
model DailyTimesheet {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("Timesheets", fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  stationaryH Float    @default(0)
  mobileH     Float    @default(0)
  travelH     Float    @default(0)
  cleaningH   Float    @default(0)
  note        String?
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
}

// Zmiany w grafiku (przypisane przez admina)
model Shift {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  start     DateTime
  end       DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([start])
}

// Dyspozycyjność zgłaszana przez pracownika
model Availability {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  start     DateTime
  end       DateTime
  note      String?
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime @default(now())

  @@index([userId])
}

// Rezerwacje (ręczne w panelu lub zaimportowane z LockMe)
model Reservation {
  id            String   @id @default(cuid())
  title         String
  roomId        String?
  room          Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  start         DateTime
  end           DateTime
  people        Int      @default(0)
  customerName  String?
  customerPhone String?
  customerEmail String?
  notes         String?
  source        String   @default("MANUAL") // MANUAL | LOCKME
  externalId    String?  @unique // identyfikator rezerwacji z LockMe
  status        String   @default("NEW") // NEW | CONFIRMED | DONE | CANCELLED
  assignedUserId String?
  assignedUser  User?    @relation("AssignedReservations", fields: [assignedUserId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer? @relation("CustomerReservations", fields: [customerId], references: [id], onDelete: SetNull)
  deposit       Float    @default(0)
  paid          Boolean  @default(false)
  refNo         String?  @unique // automatyczny numer zlecenia, np. MYS-2026-0001
  price         Float    @default(0)  // wartość/przychód
  invoiceUrl    String?  // faktura/paragon za rozgrywkę (przychód)
  fuelCost      Float    @default(0)  // koszt paliwa (wyjazdy)
  fuelInvoiceUrl String? // faktura za paliwo
  otherCost     Float    @default(0)  // inne koszty
  otherInvoiceUrl String? // faktura za inne koszty
  thankedAt     DateTime? // kiedy wysłano auto-podziękowanie po grze
  createdAt     DateTime @default(now())

  @@index([start])
}

// Wydatki firmowe (poza kosztami przypisanymi do rezerwacji) —
// dodają Księgowa i Technik; wliczane do kosztów w pulpicie finansowym.
model Expense {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  category      String   @default("INNE") // ZAKUP | NAPRAWA | KONSERWACJA | MEDIA | MARKETING | INNE
  description   String
  amount        Float    @default(0) // brutto zł
  vendor        String?  // sprzedawca / kontrahent
  invoiceNo     String?  // numer faktury/paragonu
  invoiceUrl    String?  // skan faktury/paragonu
  createdById   String?  // kto dodał (id konta)
  createdByName String?  // kto dodał (nazwa — do podglądu)
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([category])
}

// Klienci (mini-CRM) — baza z historią gier, zgodą marketingową i tagami
model Customer {
  id               String   @id @default(cuid())
  name             String?
  email            String?  @unique // klucz łączenia z rezerwacjami (gdy podany)
  phone            String?
  company          String?
  marketingConsent Boolean  @default(false)
  tagsJson         String?  @default("[]") // np. ["VIP","stały","firma"]
  notes            String?
  source           String   @default("MANUAL") // MANUAL | RESERVATION | CONTACT
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  reservations     Reservation[] @relation("CustomerReservations")

  @@index([phone])
}

// Magazyn — pozycje (bilety, gadżety, akcesoria na wyjazdy)
model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("INNE") // BILETY | GADZETY | AKCESORIA | MATERIALY | INNE
  quantity  Int      @default(0)
  unit      String   @default("szt.")
  lowStock  Int      @default(0) // próg niskiego stanu (0 = brak alertu)
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movements InventoryMovement[]

  @@index([category])
}

// Ruch magazynowy (przyjęcie +/ wydanie -)
model InventoryMovement {
  id        String   @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String?
  byName    String?
  createdAt DateTime @default(now())

  @@index([itemId])
}

// Log konserwacji pokoju (resety rekwizytów, baterie, usterki, naprawy)
model MaintenanceLog {
  id            String    @id @default(cuid())
  roomId        String?
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  type          String    @default("USTERKA") // RESET | BATERIE | USTERKA | NAPRAWA | PRZEGLAD | INNE
  description   String
  status        String    @default("OPEN") // OPEN | DONE
  priority      String    @default("NORMAL") // LOW | NORMAL | HIGH
  dueDate       DateTime? // termin / przypomnienie
  createdById   String?
  createdByName String?
  resolvedAt    DateTime?
  resolvedByName String?
  createdAt     DateTime  @default(now())

  @@index([roomId])
  @@index([status])
}

// Szablon checklisty otwarcia/zamknięcia lokalu
model ChecklistItem {
  id        String   @id @default(cuid())
  kind      String   @default("OPEN") // OPEN | CLOSE
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([kind])
}

// Odhaczenie pozycji checklisty danego dnia
model ChecklistCheck {
  id         String   @id @default(cuid())
  itemId     String
  date       DateTime // dzień (00:00 UTC)
  doneByName String?
  createdAt  DateTime @default(now())

  @@unique([itemId, date])
  @@index([date])
}

// Kampanie marketingowe (newsletter) — log wysyłek do bazy klientów
model Campaign {
  id         String   @id @default(cuid())
  subject    String
  body       String
  channel    String   @default("EMAIL") // EMAIL | TELEGRAM | BOTH
  audience   String   @default("ALL")   // ALL | nazwa tagu
  recipients Int      @default(0)
  result     String?  // krótkie podsumowanie wysyłki
  sentByName String?
  createdAt  DateTime @default(now())
}

// Kody rabatowe
model DiscountCode {  id            String   @id @default(cuid())
  code          String   @unique
  kind          String   @default("PERCENT") // PERCENT | AMOUNT
  value         Float    @default(0)
  descriptionPl String?
  descriptionEn String?
  active        Boolean  @default(true)
  usageLimit    Int      @default(0) // 0 = bez limitu
  usedCount     Int      @default(0)
  createdAt     DateTime @default(now())
}

// Bony podarunkowe
model Voucher {
  id         String   @id @default(cuid())
  code       String   @unique
  titlePl    String   @default("Bon podarunkowy")
  titleEn    String   @default("Gift voucher")
  amount     Float    @default(0) // wartość w zł (0 = bon na grę)
  status     String   @default("NEW") // NEW | SOLD | REDEEMED
  buyerName  String?
  validUntil String?  // RRRR-MM-DD
  note       String?
  createdAt  DateTime @default(now())
}

// Zapotrzebowanie na pracowników danego dnia (ustala właściciel)
model StaffingDemand {
  id          String   @id @default(cuid())
  date        DateTime @unique // dzień (00:00)
  stationary  Int      @default(0)
  mobile      Int      @default(0)
  startTime   String   @default("16:00")
  endTime     String   @default("22:00")
  note        String?
  createdAt   DateTime @default(now())
}

// Pokoje zagadek (stacjonarne + mobilne)
model Room {
  id            String   @id @default(cuid())
  slug          String   @unique
  namePl        String
  nameEn        String
  taglinePl     String?
  taglineEn     String?
  descriptionPl String?  // pełny opis (strona pokoju)
  descriptionEn String?
  image         String?  // ścieżka do zdjęcia głównego
  durationMin   Int      @default(60)
  minPlayers    Int      @default(2)
  maxPlayers    Int      @default(8)
  difficultyPl  String   @default("Średni")
  difficultyEn  String   @default("Medium")
  badgePl       String   @default("Stacjonarny")
  badgeEn       String   @default("On-site")
  imagesJson    String?  @default("[]") // galeria pokoju (JSON: tablica URLi)
  pricingJson   String?  @default("[]") // cennik wg liczby osób (JSON: [{labelPl,labelEn,price}])
  reservations  Reservation[]
  maintenanceLogs MaintenanceLog[]
  status        String   @default("ACTIVE") // ACTIVE | SOON
  theme         String   @default("default") // motyw podstrony: default|loch|pirate|horror|occult|noir|tomb|steampunk|bunker
  heroImage     String?  // opcjonalne zdjęcie tła nagłówka (puste = zdjęcie główne)
  heroVideo     String?  // opcjonalne wideo w tle nagłówka (mp4/webm, w pętli)
  bookingUrl    String?
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Oferty mobilne / wyjazdowe (np. Mobilna Skrzynia) — osobny typ z podstronami
model MobileOffer {
  id              String   @id @default(cuid())
  slug            String   @unique
  namePl          String
  nameEn          String
  taglinePl       String?
  taglineEn       String?
  descriptionPl   String?
  descriptionEn   String?
  image           String?
  imagesJson      String?  @default("[]") // galeria (JSON: tablica URLi)
  durationMin     Int      @default(60)
  minPlayers      Int      @default(2)
  maxPlayers      Int      @default(8)
  priceInfoPl     String?  // cena samej gry (tekst, np. "od 299 zł")
  priceInfoEn     String?
  pricingJson     String?  @default("[]") // cennik wg liczby osób (JSON: [{labelPl,labelEn,price}])
  travelZonesJson String?  @default("[]") // strefy dojazdu (JSON: [{labelPl,labelEn,price}])
  areaPl          String?  // obszar działania
  areaEn          String?
  requirementsPl  String?  // wymagania na miejscu
  requirementsEn  String?
  occasionsPl     String?  // dla kogo / okazje (linie lub przecinki)
  occasionsEn     String?
  badgePl         String   @default("Wyjazdowy")
  badgeEn         String   @default("Mobile")
  status          String   @default("ACTIVE") // ACTIVE | SOON
  order           Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Płatności online (Stripe / Przelewy24) — bony, eventy, zadatki
model Payment {
  id          String    @id @default(cuid())
  provider    String    @default("STRIPE") // STRIPE | P24
  purpose     String    @default("EVENT")  // VOUCHER | EVENT
  amount      Int       @default(0)         // w groszach
  currency    String    @default("PLN")
  description String?
  status      String    @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  buyerName   String?
  buyerEmail  String?
  metaJson    String?   // dane do realizacji (np. wartość bonu)
  providerRef String?   // id sesji Stripe / orderId P24
  voucherId   String?   // utworzony bon po opłaceniu
  paidAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

// Strony informacyjne/prawne (O nas, Regulamin, Polityka prywatności, Dostępność, Dla firm)
model Page {
  id           String   @id @default(cuid())
  slug         String   @unique
  titlePl      String
  titleEn      String   @default("")
  contentPl    String   @default("")
  contentEn    String   @default("")
  order        Int      @default(0)
  showInFooter Boolean  @default(true)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Blog / Aktualności (SEO)
model Post {
  id         String   @id @default(cuid())
  slug       String   @unique
  titlePl    String
  titleEn    String
  excerptPl  String?
  excerptEn  String?
  contentPl  String?
  contentEn  String?
  coverImage String?
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Galeria z eventów / realizacji (album per wydarzenie)
model EventAlbum {
  id         String   @id @default(cuid())
  slug       String   @unique
  titlePl    String
  titleEn    String
  dateLabel  String?  // np. „Marzec 2026" lub „12.03.2026"
  roomName   String?  // której gry/eventu dotyczy
  descPl     String?
  descEn     String?
  coverImage String?
  imagesJson String?  @default("[]") // tablica URLi
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Hall of Fame — ranking najlepszych drużyn (czasy ukończenia)
model LeaderboardEntry {
  id        String   @id @default(cuid())
  roomName  String   @default("") // której gry dotyczy (grupowanie)
  teamName  String
  timeMin   Int      @default(0)
  timeSec   Int      @default(0)
  players   Int      @default(0)
  dateLabel String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([roomName])
}

// Galeria zdjęć
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  captionPl String?
  captionEn String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Galeria filmów (YouTube lub plik mp4)
model Video {
  id        String   @id @default(cuid())
  titlePl   String
  titleEn   String
  type      String   @default("YOUTUBE") // YOUTUBE | FILE
  youtubeId String?
  fileUrl   String?
  thumbnail String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Opinie graczy
model Review {
  id         String   @id @default(cuid())
  authorName String
  eventPl    String?
  eventEn    String?
  textPl     String
  textEn     String
  rating     Int      @default(5)
  source     String   @default("MANUAL") // MANUAL | GOOGLE
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// Pakiety cenowe
model PricingPlan {
  id        String   @id @default(cuid())
  namePl    String
  nameEn    String
  price     String   // tekst, np. "199 zł" albo "Wycena"
  descPl    String?
  descEn    String?
  featured  Boolean  @default(false)
  ctaUrl    String?
  order     Int      @default(0)
  published Boolean  @default(true)
}

// Pytania FAQ
model FaqItem {
  id         String   @id @default(cuid())
  questionPl String
  questionEn String
  answerPl   String
  answerEn   String
  order      Int      @default(0)
  published  Boolean  @default(true)
}

// Wiadomości z formularza kontaktowego
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  coupon    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Ustawienia strony (pojedynczy wiersz, id = "main")
model SiteSettings {
  id            String  @id @default("main")
  logoUrl       String? // logo w nawigacji (upload w panelu lub /logo.png)
  addressPl     String  @default("Warszawska 40, 05-100 Nowy Dwór Mazowiecki")
  addressEn     String  @default("Warszawska 40, 05-100 Nowy Dwór Mazowiecki")
  phone         String  @default("+48 571 080 192")
  email         String  @default("artsmysterium@gmail.com")
  whatsapp      String  @default("48571080192")
  lockmeUrl     String  @default("https://lock.me")
  instagram     String?
  facebook      String?
  tiktok        String?
  youtube       String?
  parkingPl     String?
  parkingEn     String?
  googleReviewsEnabled Boolean @default(false)
  googleReviewsUrl     String?
  googleRating         String? // np. "4.9"
  // Powiadomienia
  telegramEnabled   Boolean @default(false)
  telegramBotToken  String?
  telegramChatId    String? // grupa lub osoba (id czatu)
  emailNotifyEnabled Boolean @default(false)
  notifyOnReservation Boolean @default(true)
  notifyOnMessage     Boolean @default(true)
  notifyOnSchedule    Boolean @default(true)
  // Auto-podziękowanie po grze + prośba o opinię Google
  autoThankYouEnabled Boolean @default(false)
  thankYouMessagePl   String?
  // Pop-up (promocja lub zapis do newslettera)
  popupMode       String  @default("OFF") // OFF | PROMO | NEWSLETTER
  popupTitlePl    String  @default("")
  popupTitleEn    String  @default("")
  popupTextPl     String  @default("")
  popupTextEn     String  @default("")
  popupImage      String?
  popupCtaLabelPl String  @default("")
  popupCtaLabelEn String  @default("")
  popupCtaUrl     String?
  popupDelaySec   Int     @default(6)
  // Płatności online
  paymentsEnabled Boolean @default(false)
  paymentProvider String  @default("STRIPE") // STRIPE | P24
  voucherSaleEnabled Boolean @default(false)  // zakup bonów online na /bony
  hoursPl       String  @default("Pon–Nd: 9:00–22:00")
  hoursEn       String  @default("Mon–Sun: 9:00–22:00")
  heroDescPl    String  @default("Przenieś się do świata, gdzie każda sekunda ma znaczenie.")
  heroDescEn    String  @default("Step into a world where every second counts.")
  // Sekcja „O nas" + mapa
  aboutPl       String  @default("")
  aboutEn       String  @default("")
  mapEmbed      String? // src iframe mapy (Google Maps → Udostępnij → Umieść mapę)
  mapLink       String? @default("https://maps.app.goo.gl/xWrTVhzXAN6J7UDv8")
  // Sekcja promo / odliczanie
  promoMode     String  @default("OFF") // OFF | COUNTDOWN | BANNER
  promoTitlePl  String  @default("")
  promoTitleEn  String  @default("")
  promoTextPl   String  @default("")
  promoTextEn   String  @default("")
  promoCtaLabelPl String @default("")
  promoCtaLabelEn String @default("")
  promoCtaUrl   String?
  promoDate     DateTime?
  promoVideoPl  String? // YouTube ID lub URL pliku dla sekcji intro
  lockmeWidget  String? // kod osadzenia widżetu LockMe (iframe lub script)
  // Integracja LockMe API (automatyczny import rezerwacji)
  lockmeApiUrl  String?
  lockmeApiKey  String?
  lockmeRoomId  String?
  // RCP: sekret do podpisywania kodów QR (zegar wejście/wyjście)
  clockSecret   String?
  clockCodeMode String  @default("STATIC") // STATIC = ręczna zmiana | DYNAMIC = auto-rotacja
  // Integracja Google Calendar (pełna synchronizacja — opcjonalna)
  googleSyncEnabled  Boolean @default(false)
  googleClientEmail  String?
  googlePrivateKey   String?
  googleCalendarId   String?
  updatedAt     DateTime @updatedAt
}
